code
JavaScript
import { supabase } from './seu-arquivo-supabase.js'; 
import { useState, useEffect } from 'react';

// Componente para exibir um único "card" de dashboard
function DashboardCard({ botName, stats }) {
    if (!stats) {
        return <div className="card"><h3>{botName}</h3><p>Aguardando dados...</p></div>;
    }

    // APLICANDO O MAPEAMENTO
    const victoriasDisplay = `${stats.wins}/${stats.losses}`;
    
    const winsInLast10 = 10 - stats.losses_10_count;
    const losses10Display = `${stats.losses_10_count} x ${winsInLast10}`;
    const losses10Percent = Math.round((stats.losses_10_count / 10) * 100);

    const lossesInLast5 = 5 - stats.wins_5_count;
    const wins5Display = `${stats.wins_5_count}x${lossesInLast5}`;
    const wins5Percent = Math.round(stats.wins_5_percent);

    // RENDERIZAÇÃO NO FORMATO DESEJADO
    return (
        <div className="dashboard-card" style={{ border: '1px solid gray', padding: '1em', margin: '1em' }}>
            <h3>{botName}</h3>
            <hr/>
            
            {/* Bloco 1: Victorias vs Derrotas */}
            <p>Victorias / Derrotas</p>
            <h2 id="victorias-derrotas">{victoriasDisplay}</h2>
            
            {/* Bloco 2: Losses 10 Ops */}
            <p>Losses 10 Ops</p>
            <h2 id="losses-10-display">{losses10Display}</h2>
            <small id="losses-10-percent">{losses10Percent}%</small>
            
            {/* Bloco 3: Wins 5 Ops */}
            <p>Wins 5 Ops</p>
            <h2 id="wins-5-display">{wins5Display}</h2>
            <small id="wins-5-percent">{wins5Percent}%</small>
        </div>
    );
}

// Componente principal que busca todos os dados
function ControlRoom() {
    const BOT_NAMES = ['Scalping Bot', 'Tunder Bot'];
    const [allDashboards, setAllDashboards] = useState([]);
    const [loading, setLoading] = useState(true);

    useEffect(() => {
        async function fetchAllData() {
            const promises = BOT_NAMES.map(name => 
                supabase.rpc('get_scalping_dashboard', { p_bot_name: name }).single()
            );
            const results = await Promise.all(promises);
            const formattedData = results.map((res, i) => ({ name: BOT_NAMES[i], stats: res.data }));
            setAllDashboards(formattedData);
            setLoading(false);
        }
        fetchAllData();
    }, []);

    if (loading) return <p>Carregando Painel de Controle...</p>;

    return (
        <div style={{ display: 'flex' }}>
            {allDashboards.map(dash => (
                <DashboardCard key={dash.name} botName={dash.name} stats={dash.stats} />
            ))}
        </div>
    );
}```