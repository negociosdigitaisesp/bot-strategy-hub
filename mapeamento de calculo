Cálculos e Formatação (dentro do loop de renderização):
code
JavaScript
// Para cada 'dashboard' no array 'allDashboards'
const stats = dashboard.stats;

// 1. VICTORIAS vs DERROTAS
//    Usa o total de wins/losses, que é mais relevante que apenas das últimas 20.
const victoriasDisplay = `${stats.wins}/${stats.losses}`;  // Ex: "150/45"

// 2. LOSSES 10 OPS
//    Calculamos as vitórias assumindo 10 operações no total.
const winsInLast10 = 10 - stats.losses_10_count;
const losses10Display = `${stats.losses_10_count} x ${winsInLast10}`;  // Ex: "7 x 3"
const losses10Percent = Math.round((stats.losses_10_count / 10) * 100); // Ex: 70%

// 3. WINS 5 OPS
//    Calculamos as derrotas assumindo 5 operações no total.
const lossesInLast5 = 5 - stats.wins_5_count;
const wins5Display = `${stats.wins_5_count}x${lossesInLast5}`;  // Ex: "4x1"
const wins5Percent = Math.round(stats.wins_5_percent); // Ex: 80% (já vem calculado)
