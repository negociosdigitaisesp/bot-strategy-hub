# Variáveis de Ambiente para QA Suite
# Copie este arquivo para .env.qa e preencha com seus valores

# ============================================
# VPS ACCESS
# ============================================
VPS_HOST=your-vps-ip-here
VPS_USER=root
VPS_SSH_KEY=~/.ssh/id_rsa

# ============================================
# SUPABASE
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# DERIV API
# ============================================
DERIV_APP_ID=your-deriv-app-id
DERIV_API_TOKEN=your-deriv-api-token

# ============================================
# FRONTEND
# ============================================
# URL do frontend para testes (dev server ou deploy)
FRONTEND_URL=http://localhost:5173
# Ou para produção:
# FRONTEND_URL=https://your-app.vercel.app

# ============================================
# TEST CONFIGURATION
# ============================================
# Timeout padrão para testes (ms)
QA_TIMEOUT_MS=30000

# Threshold de performance (ms)
QA_PERFORMANCE_THRESHOLD_MS=500

# Modo de teste (development ou production)
QA_MODE=development

# ============================================
# OPTIONAL: SLACK/DISCORD WEBHOOKS
# ============================================
# Para enviar alertas automáticos
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
