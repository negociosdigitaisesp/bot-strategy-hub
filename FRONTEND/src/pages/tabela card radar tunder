### 8. **EXEMPLO DE IMPLEMENTAÇÃO**

#### MetricsDashboard.jsx
```jsx
import React from 'react';
import { useMetricsData } from '../hooks/useMetricsData';
import BotMetricsCard from './BotMetricsCard';
import MartingaleAnalysis from './MartingaleAnalysis';
import MarketConditions from './MarketConditions';

const MetricsDashboard = () => {
  const { data: metrics, loading, error } = useMetricsData(null, true);

  if (loading) return <LoadingSpinner />;
  if (error) return <ErrorMessage error={error} />;

  return (
    <div className="metrics-dashboard">
      <h1>Dashboard de Métricas Consolidadas</h1>
      
      {/* Visão Geral */}
      <div className="overview-section">
        <div className="metrics-grid">
          {metrics.map(bot => (
            <BotMetricsCard key={bot.bot_name} bot={bot} />
          ))}
        </div>
      </div>

      {/* Análise de Martingale */}
      <MartingaleAnalysis metrics={metrics} />

      {/* Condições de Mercado */}
      <MarketConditions />
    </div>
  );
};

export default MetricsDashboard;
```

### 9. **QUERIES OTIMIZADAS**

#### Busca de Métricas em Tempo Real
```javascript
// Implementar subscription para updates em tempo real
const subscription = supabase
  .channel('metrics-updates')
  .on('postgres_changes', 
    { 
      event: '*', 
      schema: 'public', 
      table: 'bot_metrics_consolidated' 
    }, 
    (payload) => {
      // Atualizar estado local
      updateMetrics(payload.new);
    }
  )
  .subscribe();
```

