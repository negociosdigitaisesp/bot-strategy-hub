## 🚀 Exemplos de Uso no Frontend

### 1. **Dashboard em Tempo Real**
```javascript
// Supabase Client
import { createClient } from '@supabase/supabase-js'

const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY)

// Buscar logs em tempo real
const { data, error } = await supabase
  .from('radar_de_apalancamiento_signals')
  .select('*')
  .gte('pattern_found_at', new Date(Date.now() - 24*60*60*1000).toISOString()) // Últimas 24h
  .order('pattern_found_at', { ascending: false })

// Subscription para updates em tempo real
const subscription = supabase
  .channel('logs-realtime')
  .on('postgres_changes', 
    { event: 'INSERT', schema: 'public', table: 'radar_de_apalancamiento_signals' },
    (payload) => {
      console.log('Novo log:', payload.new)
      // Atualizar UI
    }
  )
  .subscribe()
```

### 2. **Filtrar por Tipo de Log**
```javascript
// Buscar apenas logs de análise
const { data: analysisLogs } = await supabase
  .from('radar_de_apalancamiento_signals')
  .select('*')
  .eq('strategy_used', 'Log-ANALISIS')
  .order('pattern_found_at', { ascending: false })
  .limit(10)

// Buscar apenas erros
const { data: errorLogs } = await supabase
  .from('radar_de_apalancamiento_signals')
  .select('*')
  .in('strategy_used', ['Log-ERROR_CICLO', 'Log-ERROR_CRITICO'])
  .order('pattern_found_at', { ascending: false })
```

### 3. **Extrair Dados JSON**
```javascript
// Buscar métricas com dados JSON
const { data: metricsLogs } = await supabase
  .from('radar_de_apalancamiento_signals')
  .select('reason, last_operations, pattern_found_at')
  .eq('strategy_used', 'Log-METRICAS')
  .order('pattern_found_at', { ascending: false })
  .limit(1)

if (metricsLogs.length > 0) {
  const metrics = JSON.parse(metricsLogs[0].last_operations)
  console.log('Total operações:', metrics.total_operaciones)
  console.log('Win rate:', metrics.porcentaje_wins)
  console.log('Intensidade Martingale:', metrics.intensidad_martingale)
}
```

### 4. **Componente React para Logs**
```jsx
import React, { useState, useEffect } from 'react'
import { createClient } from '@supabase/supabase-js'

const LogsComponent = () => {
  const [logs, setLogs] = useState([])
  const [filter, setFilter] = useState('all')
  
  const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY)
  
  useEffect(() => {
    fetchLogs()
    
    // Subscription para updates em tempo real
    const subscription = supabase
      .channel('logs-realtime')
      .on('postgres_changes', 
        { event: 'INSERT', schema: 'public', table: 'radar_de_apalancamiento_signals' },
        (payload) => {
          setLogs(prev => [payload.new, ...prev])
        }
      )
      .subscribe()
      
    return () => subscription.unsubscribe()
  }, [filter])
  
  const fetchLogs = async () => {
    let query = supabase
      .from('radar_de_apalancamiento_signals')
      .select('*')
      .order('pattern_found_at', { ascending: false })
      .limit(50)
    
    if (filter !== 'all') {
      query = query.eq('strategy_used', `Log-${filter}`)
    }
    
    const { data, error } = await query
    if (!error) setLogs(data)
  }
  
  return (
    <div>
      <select value={filter} onChange={(e) => setFilter(e.target.value)}>
        <option value="all">Todos os Logs</option>
        <option value="CICLO">Ciclos</option>
        <option value="ANALISIS">Análises</option>
        <option value="METRICAS">Métricas</option>
        <option value="ERROR_CICLO">Erros</option>
      </select>
      
      <div>
        {logs.map(log => (
          <div key={log.id} className={`log-item ${log.strategy_confidence === 0 ? 'error' : ''}`}>
            <span className="timestamp">{new Date(log.pattern_found_at).toLocaleString()}</span>
            <span className="type">{log.strategy_used}</span>
            <span className="message">{log.reason}</span>
            {log.last_operations !== '{}' && (
              <details>
                <summary>Dados Adicionais</summary>
                <pre>{JSON.stringify(JSON.parse(log.last_operations), null, 2)}</pre>
              </details>
            )}
          </div>
        ))}
      </div>
    </div>
  )
}
```

## 📈 Queries Úteis para Analytics

### 1. **Estatísticas de Performance**
```sql
-- Contagem de logs por tipo nas últimas 24h
SELECT 
  strategy_used,
  COUNT(*) as total,
  AVG(strategy_confidence) as avg_confidence
FROM radar_de_apalancamiento_signals 
WHERE pattern_found_at >= NOW() - INTERVAL '24 hours'
GROUP BY strategy_used
ORDER BY total DESC;
```

### 2. **Logs de Erro**
```sql
-- Todos os erros nas últimas 24h
SELECT 
  pattern_found_at,
  reason,
  last_operations
FROM radar_de_apalancamiento_signals 
WHERE strategy_confidence = 0 
  AND pattern_found_at >= NOW() - INTERVAL '24 hours'
ORDER BY pattern_found_at DESC;
```

### 3. **Análises de Mercado Recentes**
```sql
-- Últimas 10 análises de mercado
SELECT 
  pattern_found_at,
  reason,
  last_operations
FROM radar_de_apalancamiento_signals 
WHERE strategy_used = 'Log-ANALISIS'
ORDER BY pattern_found_at DESC
LIMIT 10;
```

### 4. **Métricas de Operações**
```sql
-- Extrair métricas das operações
SELECT 
  pattern_found_at,
  last_operations::json->>'total_operaciones' as total_ops,
  last_operations::json->>'porcentaje_wins' as win_rate,
  last_operations::json->>'intensidad_martingale' as martingale_intensity
FROM radar_de_apalancamiento_signals 
WHERE strategy_used = 'Log-METRICAS'
ORDER BY pattern_found_at DESC;
```

